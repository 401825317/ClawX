{
  "provider": {
    "productionOrigin": "https://zz-cn.lingzhiwuxian.com",
    "providerName": "UClaw",
    "managedProviderId": "openai",
    "managedAccountId": "openai",
    "authAccountId": "uclaw-auth",
    "legacyProviderIds": ["openai-codex", "lingzhiwuxian"],
    "legacyAuthAccountIds": ["lingzhiwuxian-auth"],
    "defaultModel": "smart-latest",
    "defaultModelContextWindow": 258000,
    "defaultApiProtocol": "openai-responses",
    "defaultThinkingLevel": "medium",
    "requestTimeoutSeconds": 300
  },
  "auth": {
    "requestTimeoutMs": 12000,
    "bootstrapRequestTimeoutMs": 8000,
    "relayRequestTimeoutMs": 12000,
    "verificationRequestTimeoutMs": 12000,
    "offlineGraceSeconds": 604800,
    "verifyMemoryCacheSeconds": 300,
    "tokenRefreshSkewSeconds": 300,
    "defaultAccessTokenLifetimeSeconds": 86400
  },
  "marketplace": {
    "defaultProvider": "skillhub",
    "skillHubApiOrigin": "https://api.skillhub.cn",
    "skillHubWebOrigin": "https://skillhub.cn",
    "clawHubConvexOrigin": "https://wry-manatee-359.convex.cloud",
    "clawHubMirrorOrigin": "https://mirror-cn.clawhub.com",
    "clawHubInstallOrigin": "https://clawhub.ai",
    "requestTimeoutMs": 15000,
    "downloadTimeoutMs": 90000,
    "maxJsonBytes": 4194304,
    "maxDownloadBytes": 33554432,
    "maxArchiveFiles": 512,
    "maxArchiveEntryBytes": 16777216,
    "maxArchiveUncompressedBytes": 67108864
  },
  "billing": {
    "requestTimeoutMs": 12000,
    "orderStatusPollIntervalMs": 2000,
    "historyPageSize": 20,
    "routes": {
      "overview": "/api/clawx/billing/checkout-info",
      "orders": "/api/clawx/billing/orders",
      "history": "/api/clawx/billing/orders/history",
      "verify": "/api/clawx/billing/orders/verify"
    }
  },
  "support": {
    "requestTimeoutMs": 8000,
    "refreshIntervalMs": 600000,
    "routes": {
      "clientConfig": "/api/clawx/client-config",
      "bootstrap": "/api/clawx/bootstrap"
    }
  },
  "runtimeDefaults": {
    "tools": {
      "exec": {
        "security": "full",
        "ask": "off"
      }
    },
    "compaction": {
      "mode": "safeguard",
      "reserveTokensFloor": 50000
    }
  },
  "media": {
    "image": {
      "timeoutMs": 1800000,
      "defaultSize": "1024x1024"
    },
    "video": {
      "timeoutMs": 1800000,
      "pollIntervalMs": 5000,
      "maxDownloadBytes": 1073741824,
      "preferredResolution": "480p",
      "preferredShortEdge": 480
    },
    "testTimeoutMs": 1800000,
    "clientTimeoutBufferMs": 10000
  }
}
